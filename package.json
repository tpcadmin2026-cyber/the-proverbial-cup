{
  "name": "gazette-platform",
  "version": "1.0.3",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "build": "sh -c 'DATABASE_URL=${DATABASE_URL:-postgresql://localhost/build} prisma generate' && next build",
    "start": "next start",
    "start:prod": "prisma db push && next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "create-admin": "tsx prisma/create-admin.ts"
  },
