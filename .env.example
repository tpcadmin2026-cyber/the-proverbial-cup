# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/gazette_platform"

# ── NextAuth ───────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ── Site URL (required in production) ────────────────────────────────────
# Set to your full domain, e.g. https://yourdomain.com — used by sitemap.xml and robots.txt
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Resend (email) ────────────────────────────────────────────────────────
RESEND_API_KEY=""

# ── Twilio (SMS) ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── Cloudflare R2 (media storage) ────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ── Backblaze B2 (backups) ────────────────────────────────────────────────
B2_KEY_ID=""
B2_APPLICATION_KEY=""
B2_BUCKET_ID=""
B2_BUCKET_NAME=""
B2_ENDPOINT=""

# ── PostHog (analytics) ───────────────────────────────────────────────────
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ── Anthropic (AI chat) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ── GitHub (deploy integration) ───────────────────────────────────────────
GITHUB_TOKEN=""
GITHUB_REPO=""

# ── Vercel (deploy) ───────────────────────────────────────────────────────
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""

# ── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Platform ──────────────────────────────────────────────────────────────
# Set to "true" after setup wizard is complete
SETUP_COMPLETE="false"
